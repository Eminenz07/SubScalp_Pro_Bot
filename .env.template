# ── MT5 (local Windows only — not used on Railway) ──────────────────────────
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=

# ── Deriv API (primary broker on Railway) ────────────────────────────────────
# Get these from: https://app.deriv.com/account/api-token
# Create a token with: Read, Trade, Payments, Admin scope
DERIV_APP_ID=1089
DERIV_API_TOKEN=your_deriv_api_token_here

# Set to true to enable live data + trading without changing config.json
# Useful for Railway where you set this as an environment variable
DERIV_LIVE=true

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_SECRET_KEY=change-this-to-a-random-string

# ── Notifications ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_TO=
